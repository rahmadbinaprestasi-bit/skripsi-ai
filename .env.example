# Environment Variables for skripsiAi
# ⚠️ DO NOT COMMIT THIS FILE TO GITHUB ⚠️
# Set these values in Vercel Dashboard for production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.7

# Duitku Payment
DUITKU_MERCHANT_CODE=Dxxxx
DUITKU_API_KEY=your-duitku-api-key
DUITKU_CALLBACK_URL=http://localhost:3000/api/webhook/duitku
DUITKU_RETURN_URL=http://localhost:3000/subscription?status=success
DUITKU_IS_SANDBOX=true

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token